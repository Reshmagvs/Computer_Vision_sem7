import numpy as np 
import matplotlib.pyplot as plt 
import scipy.ndimage as nd 
from PIL import Image

from skimage.feature import canny 
from skimage import segmentation, filters 
from skimage.color import rgb2gray, label2rgb 


plt.rcParams["figure.figsize"] = (12, 8) 
%matplotlib inline 


try:
    original_img = np.array(Image.open('sample.jpg'))
    img_gray = rgb2gray(original_img) 
except FileNotFoundError:
    print("Error: Could not find 'sample.jpg'. Please ensure it is in your notebook folder.")


edges = canny(img_gray, sigma=1.5) 

 
fill_im = nd.binary_fill_holes(edges) 


elevation_map = filters.sobel(img_gray) 


mean_brightness = np.mean(img_gray)
markers = np.zeros_like(img_gray, dtype=np.int32) 
markers[img_gray < (mean_brightness * 0.5)] = 1  
markers[img_gray > (mean_brightness * 1.5)] = 2  

segments = segmentation.watershed(elevation_map, markers) 

segments_filled = nd.binary_fill_holes(segments - 1) 
label_objects, _ = nd.label(segments_filled) 

image_label_overlay = label2rgb(label_objects, image=img_gray, bg_label=0) 


fig, axs = plt.subplots(2, 3, figsize=(18, 10))

axs[0, 0].imshow(img_gray, cmap='gray')
axs[0, 0].set_title('Original Grayscale')
axs[0, 0].axis('off')

axs[0, 1].imshow(edges, cmap='gray')
axs[0, 1].set_title('1. Canny Edges')
axs[0, 1].axis('off')

axs[0, 2].imshow(fill_im, cmap='gray')
axs[0, 2].set_title('2. Region Filling')
axs[0, 2].axis('off')

axs[1, 0].imshow(elevation_map, cmap='magma')
axs[1, 0].set_title('3. Sobel Elevation Map')
axs[1, 0].axis('off')

axs[1, 1].imshow(segments, cmap='jet')
axs[1, 1].set_title('4. Watershed Segments')
axs[1, 1].axis('off')

axs[1, 2].imshow(image_label_overlay)
axs[1, 2].set_title('5. Final Mask Overlay')
axs[1, 2].axis('off')

plt.tight_layout()
plt.show() 
