import os
import cv2 
import requests
import numpy as np 
from PIL import Image 
from IPython.display import display


files_to_download = {
    "vehicle.xml": "https://raw.githubusercontent.com/andrewssobral/vehicle_detection_haarcascades/master/cars.xml",
    "sample.jpg": "https://raw.githubusercontent.com/andrewssobral/vehicle_detection_haarcascades/master/images/car_1.png"
}

print("Checking environment files...")
for filename, url in files_to_download.items():
    if not os.path.exists(filename):
        print(f"-> Downloading missing file: {filename}...")
        response = requests.get(url)
        with open(filename, 'wb') as f:
            f.write(response.content)
print("Setup complete! All necessary files are present.\n")


image_url = 'sample.jpg' 

try:
    image = Image.open(image_url) 
    image = image.resize((450, 250)) 
    print("Original Input View:")
    display(image)
except FileNotFoundError:
    print(f"Error: Could not locate '{image_url}' even after download check.")

# 2. Image Processing Pipeline
image_arr = np.array(image) 
grey = cv2.cvtColor(image_arr, cv2.COLOR_BGR2GRAY) 
blur = cv2.GaussianBlur(grey, (5, 5), 0) 
dilated = cv2.dilate(blur, np.ones((3, 3))) 

kernel = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (2, 2)) 
closing = cv2.morphologyEx(dilated, cv2.MORPH_CLOSE, kernel) 


car_cascade_src = "vehicle.xml" 
car_cascade = cv2.CascadeClassifier(car_cascade_src) 

if car_cascade.empty():
    print(f"\nError: Could not load classifier metadata from '{car_cascade_src}'.")
else:

    cars = car_cascade.detectMultiScale(closing, 1.1, 2) 
    
    cnt = 0 
    for (x, y, w, h) in cars: 

        cv2.rectangle(image_arr, (x, y), (x + w, y + h), (255, 0, 0), 2) 
        cnt += 1 
        
    print(f"\nVehicles Detected: {cnt}")


    annotated_image = Image.fromarray(image_arr) 
    print("Annotated Detection Result:")
    display(annotated_image)
